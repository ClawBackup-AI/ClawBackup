{
  "id": "clawbackup",
  "name": "ClawBackup",
  "description": "Enhanced backup plugin - supports encryption, cloud storage, cross-device recovery, and file snapshot rollback",
  "version": "1.1.0",
  "main": "dist/index.js",
  "author": "ClawBackup Team",
  "license": "Apache-2.0",
  "homepage": "https://clawbackup.com",
  "repository": "https://github.com/ClawBackup-AI/ClawBackup",
  "configSchema": {
    "type": "object",
    "properties": {
      "defaultStorage": {
        "type": "string",
        "description": "Default storage backend",
        "default": "local"
      },
      "encryption": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable encryption"
          },
          "algorithm": {
            "type": "string",
            "default": "AES-256-CBC",
            "description": "Encryption algorithm"
          }
        }
      },
      "autoBackup": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable automatic backup"
          },
          "schedule": {
            "type": "string",
            "default": "0 2 * * *",
            "description": "Scheduled backup plan (cron format)"
          }
        }
      },
      "snapshots": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable file snapshot for rollback"
          },
          "filter": {
            "type": "object",
            "properties": {
              "maxFileSize": {
                "type": "number",
                "default": 104857600,
                "description": "Maximum file size to snapshot (bytes), default 100MB"
              },
              "excludeExtensions": {
                "type": "array",
                "items": { "type": "string" },
                "description": "File extensions to exclude from snapshots"
              },
              "excludePatterns": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Glob patterns to exclude from snapshots"
              }
            }
          },
          "retention": {
            "type": "object",
            "properties": {
              "maxTotalSizeMB": {
                "type": "number",
                "default": 5000,
                "description": "Maximum total storage size for snapshots (MB), default 5GB"
              },
              "cleanupTriggers": {
                "type": "object",
                "properties": {
                  "onSessionEnd": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run cleanup on session end"
                  },
                  "onStartup": {
                    "type": "boolean",
                    "default": true,
                    "description": "Run cleanup on startup"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "defaultStorage": {
      "label": "Default Storage",
      "help": "Select the default storage location for backups",
      "sensitive": false
    },
    "encryption.enabled": {
      "label": "Enable Encryption",
      "help": "Backups will be encrypted when enabled",
      "sensitive": false
    },
    "autoBackup.enabled": {
      "label": "Automatic Backup",
      "help": "Automatically create backups on schedule",
      "sensitive": false
    },
    "snapshots.enabled": {
      "label": "Enable Snapshots",
      "help": "Automatically create file snapshots before modifications for rollback support",
      "sensitive": false
    },
    "snapshots.retention.maxTotalSizeMB": {
      "label": "Max Snapshot Storage",
      "help": "Maximum storage space for snapshots in MB (default: 5000 = 5GB)",
      "sensitive": false
    }
  },
  "commands": [
    {
      "name": "create",
      "description": "Create backup"
    },
    {
      "name": "restore",
      "description": "Restore backup"
    },
    {
      "name": "list",
      "description": "List backups"
    },
    {
      "name": "sync",
      "description": "Sync backup to remote"
    },
    {
      "name": "delete",
      "description": "Delete backup"
    },
    {
      "name": "verify",
      "description": "Verify backup"
    },
    {
      "name": "status",
      "description": "Backup status overview"
    },
    {
      "name": "backends",
      "description": "Storage backend management"
    },
    {
      "name": "backends add",
      "description": "Add storage backend"
    },
    {
      "name": "backends remove",
      "description": "Remove storage backend"
    },
    {
      "name": "init",
      "description": "Initialize ClawBackup configuration"
    },
    {
      "name": "snapshot",
      "description": "File snapshot management"
    },
    {
      "name": "snapshot status",
      "description": "Show snapshot storage status"
    },
    {
      "name": "snapshot list",
      "description": "List snapshot events"
    },
    {
      "name": "snapshot rollback",
      "description": "Rollback files to previous state"
    },
    {
      "name": "snapshot cleanup",
      "description": "Cleanup old snapshots"
    }
  ],
  "tools": [
    {
      "name": "backup_create",
      "description": "Create OpenClaw data backup"
    },
    {
      "name": "backup_restore",
      "description": "Restore backup"
    },
    {
      "name": "backup_list",
      "description": "List all backups"
    },
    {
      "name": "backup_sync",
      "description": "Sync backup to remote storage"
    },
    {
      "name": "backup_delete",
      "description": "Delete backup"
    },
    {
      "name": "backup_verify",
      "description": "Verify backup integrity"
    },
    {
      "name": "backup_status",
      "description": "Get backup status overview"
    },
    {
      "name": "snapshot_status",
      "description": "Get snapshot storage status"
    },
    {
      "name": "snapshot_list",
      "description": "List snapshot events with optional filters"
    },
    {
      "name": "snapshot_rollback",
      "description": "Rollback files to a previous state"
    },
    {
      "name": "snapshot_history",
      "description": "Get detailed history of file modifications"
    }
  ],
  "hooks": [
    "session_start",
    "session_end",
    "before_tool_call"
  ]
}
