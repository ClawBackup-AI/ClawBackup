{
  "name": "@clawbackup-ai/clawbackup-plugin",
  "version": "1.0.0",
  "description": "Enhanced backup plugin - supports encryption, cloud storage, and cross-device recovery",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "backup",
    "encryption",
    "cloud-storage",
    "s3",
    "oss",
    "plugin"
  ],
  "author": "ClawBackup Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClawBackup-AI/ClawBackup.git"
  },
  "bugs": {
    "url": "https://github.com/ClawBackup-AI/ClawBackup/issues"
  },
  "homepage": "https://github.com/ClawBackup-AI/ClawBackup#readme",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tar": "^6.1.0",
    "oxlint": "^0.16.0",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.600.0",
    "tar": "^7.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.7"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
